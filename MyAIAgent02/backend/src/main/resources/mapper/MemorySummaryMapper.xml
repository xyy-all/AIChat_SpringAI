<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.aiagent.mapper.MemorySummaryMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.example.aiagent.entity.MemorySummaryEntity">
        <id column="memory_id" property="memoryId" />
        <result column="session_id" property="sessionId" />
        <result column="summary_type" property="summaryType" />
        <result column="summary_content" property="summaryContent" />
        <result column="embedding_vector" property="embeddingVector" 
                        typeHandler="com.example.aiagent.handle.ListDoubleTypeHandler" />
        <result column="importance_score" property="importanceScore" />
        <result column="created_at" property="createdAt" />
        <result column="updated_at" property="updatedAt" />
        <result column="expires_at" property="expiresAt" />
        <result column="metadata" property="metadata" 
                typeHandler="com.example.aiagent.handle.FastJsonTypeHandler" />
        <result column="is_deleted" property="isDeleted" />
    </resultMap>


    <!-- 根据会话ID查询记忆摘要 -->
    <select id="selectBySessionId" parameterType="string" resultMap="BaseResultMap">
        SELECT * FROM ai_memory_summary 
        WHERE session_id = #{sessionId} 
        ORDER BY importance_score DESC, created_at DESC
    </select>


    <!-- 更新记忆摘要内容 -->
    <update id="update" parameterType="com.example.aiagent.entity.MemorySummaryEntity">
        UPDATE ai_memory_summary SET
            summary_content = #{summaryContent},
            embedding_vector = #{embeddingVector,typeHandler=com.example.aiagent.handle.ListDoubleTypeHandler},
            importance_score = #{importanceScore},
            updated_at = #{updatedAt},
            expires_at = #{expiresAt},
            metadata = #{metadata}
        WHERE memory_id = #{memoryId}
    </update>


    <!-- 删除会话的所有记忆摘要 -->
    <delete id="deleteBySessionId" parameterType="string">
        DELETE FROM ai_memory_summary WHERE session_id = #{sessionId}
    </delete>


</mapper>