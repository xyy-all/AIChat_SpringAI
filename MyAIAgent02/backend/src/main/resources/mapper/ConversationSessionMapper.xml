<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.aiagent.mapper.ConversationSessionMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.example.aiagent.entity.ConversationSessionEntity">
        <id column="session_id" property="sessionId" />
        <result column="title" property="title" />
        <result column="created_at" property="createdAt" />
        <result column="last_active_at" property="lastActiveAt" />
        <result column="message_count" property="messageCount" />
        <result column="status" property="status" />
        <result column="storage_level" property="storageLevel" />
        <result column="user_id" property="userId" />
        <result column="model" property="model" />
        <result column="temperature" property="temperature" />
        <result column="max_tokens" property="maxTokens" />
        <result column="custom_attributes" property="customAttributes" 
                typeHandler="com.example.aiagent.handle.FastJsonTypeHandler" />
        <result column="metadata" property="metadata" 
                typeHandler="com.example.aiagent.handle.FastJsonTypeHandler" />
        <result column="is_deleted" property="isDeleted" />
    </resultMap>

    <!-- 根据会话ID查询 -->
    <select id="selectBySessionId" parameterType="string" resultMap="BaseResultMap">
        SELECT * FROM ai_conversation_session WHERE session_id = #{sessionId}
    </select>

    <!-- 更新会话信息 -->
    <update id="update" parameterType="com.example.aiagent.entity.ConversationSessionEntity">
        UPDATE ai_conversation_session SET
            title = #{title},
            last_active_at = #{lastActiveAt},
            message_count = #{messageCount},
            status = #{status},
            storage_level = #{storageLevel},
            user_id = #{userId},
            model = #{model},
            temperature = #{temperature},
            max_tokens = #{maxTokens},
            custom_attributes = #{customAttributes},
            metadata = #{metadata}
        WHERE session_id = #{sessionId}
    </update>

    <!-- 删除会话（逻辑删除） -->
    <update id="deleteBySessionId" parameterType="string">
        UPDATE ai_conversation_session SET status = 3 WHERE session_id = #{sessionId}
    </update>

    <!-- 查询所有活跃会话 -->
    <select id="selectAllActive" resultMap="BaseResultMap">
        SELECT * FROM ai_conversation_session 
        WHERE status = 1 
        ORDER BY last_active_at DESC
    </select>

    <!-- 查询指定用户的会话 -->
    <select id="selectByUserId" parameterType="string" resultMap="BaseResultMap">
        SELECT * FROM ai_conversation_session 
        WHERE user_id = #{userId} AND status = 1 
        ORDER BY last_active_at DESC
    </select>


    <!-- 更新最后活跃时间 -->
    <update id="updateLastActive">
        UPDATE ai_conversation_session 
        SET last_active_at = #{lastActiveAt} 
        WHERE session_id = #{sessionId}
    </update>

    <!-- 更新消息计数 -->
    <update id="incrementMessageCount" parameterType="string">
        UPDATE ai_conversation_session 
        SET message_count = message_count + 1 
        WHERE session_id = #{sessionId}
    </update>

    <!-- 更新存储层级 -->
    <update id="updateStorageLevel">
        UPDATE ai_conversation_session 
        SET storage_level = #{storageLevel} 
        WHERE session_id = #{sessionId}
    </update>

    <!-- 检查会话是否存在 -->
    <select id="existsBySessionId" parameterType="string" resultType="boolean">
        SELECT COUNT(*) > 0 
        FROM ai_conversation_session 
        WHERE session_id = #{sessionId}
    </select>

</mapper>